{
  "name": "codrag-vscode",
  "displayName": "CoDRAG — Local Code Context Engine",
  "description": "Local-first semantic code search, context assembly, and structural trace for AI workflows. No code upload. Works with Copilot, Cursor, Windsurf via MCP.",
  "version": "0.1.0",
  "publisher": "magnetic-anomaly",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/magnetic-anomaly/codrag"
  },
  "bugs": {
    "url": "https://github.com/magnetic-anomaly/codrag/issues"
  },
  "homepage": "https://codrag.io",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "code search",
    "context",
    "RAG",
    "MCP",
    "local-first",
    "semantic search",
    "codrag"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "media/codrag-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codrag",
          "title": "CoDRAG",
          "icon": "media/codrag-sidebar.svg"
        }
      ]
    },
    "views": {
      "codrag": [
        {
          "id": "codrag.projects",
          "name": "Projects",
          "icon": "media/codrag-sidebar.svg"
        },
        {
          "id": "codrag.fileTree",
          "name": "File Tree",
          "icon": "media/codrag-sidebar.svg"
        },
        {
          "id": "codrag.indexStatus",
          "name": "Index Status",
          "icon": "media/codrag-sidebar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "codrag.search",
        "title": "CoDRAG: Search",
        "icon": "$(search)"
      },
      {
        "command": "codrag.assembleContext",
        "title": "CoDRAG: Assemble Context",
        "icon": "$(file-code)"
      },
      {
        "command": "codrag.buildIndex",
        "title": "CoDRAG: Build Index",
        "icon": "$(database)"
      },
      {
        "command": "codrag.addProject",
        "title": "CoDRAG: Add Project",
        "icon": "$(add)"
      },
      {
        "command": "codrag.removeProject",
        "title": "CoDRAG: Remove Project",
        "icon": "$(trash)"
      },
      {
        "command": "codrag.copyMCPConfig",
        "title": "CoDRAG: Copy MCP Config",
        "icon": "$(clippy)"
      },
      {
        "command": "codrag.openDashboard",
        "title": "CoDRAG: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "codrag.startDaemon",
        "title": "CoDRAG: Start Daemon",
        "icon": "$(play)"
      },
      {
        "command": "codrag.stopDaemon",
        "title": "CoDRAG: Stop Daemon",
        "icon": "$(debug-stop)"
      },
      {
        "command": "codrag.enterLicenseKey",
        "title": "CoDRAG: Enter License Key",
        "icon": "$(key)"
      },
      {
        "command": "codrag.deactivateLicense",
        "title": "CoDRAG: Deactivate License",
        "icon": "$(key)"
      },
      {
        "command": "codrag.startWatcher",
        "title": "CoDRAG: Start Watcher",
        "icon": "$(eye)"
      },
      {
        "command": "codrag.stopWatcher",
        "title": "CoDRAG: Stop Watcher",
        "icon": "$(eye-closed)"
      },
      {
        "command": "codrag.traceLookup",
        "title": "CoDRAG: Trace Lookup",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "codrag.refreshProjects",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codrag.refreshFileTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codrag.selectProject",
        "title": "Select Project"
      },
      {
        "command": "codrag.rebuildProject",
        "title": "Rebuild Index",
        "icon": "$(sync)"
      },
      {
        "command": "codrag.pinFile",
        "title": "Pin File",
        "icon": "$(pin)"
      },
      {
        "command": "codrag.unpinFile",
        "title": "Unpin File",
        "icon": "$(pinned)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codrag.refreshProjects",
          "when": "view == codrag.projects",
          "group": "navigation"
        },
        {
          "command": "codrag.addProject",
          "when": "view == codrag.projects",
          "group": "navigation"
        },
        {
          "command": "codrag.refreshFileTree",
          "when": "view == codrag.fileTree",
          "group": "navigation"
        },
        {
          "command": "codrag.refreshIndexStatus",
          "when": "view == codrag.indexStatus",
          "group": "navigation"
        },
        {
          "command": "codrag.startWatcher",
          "when": "view == codrag.indexStatus",
          "group": "inline"
        },
        {
          "command": "codrag.stopWatcher",
          "when": "view == codrag.indexStatus",
          "group": "inline"
        },
        {
          "command": "codrag.openDashboard",
          "when": "view == codrag.indexStatus",
          "group": "inline"
        }
      ],
      "view/item/context": [
        {
          "command": "codrag.selectProject",
          "when": "view == codrag.projects && viewItem == project",
          "group": "inline"
        },
        {
          "command": "codrag.rebuildProject",
          "when": "view == codrag.projects && viewItem == project",
          "group": "1_actions"
        },
        {
          "command": "codrag.removeProject",
          "when": "view == codrag.projects && viewItem == project",
          "group": "2_destructive"
        },
        {
          "command": "codrag.copyMCPConfig",
          "when": "view == codrag.projects && viewItem == project",
          "group": "1_actions"
        },
        {
          "command": "codrag.pinFile",
          "when": "view == codrag.fileTree && viewItem == file",
          "group": "inline"
        },
        {
          "command": "codrag.unpinFile",
          "when": "view == codrag.fileTree && viewItem == pinnedFile",
          "group": "inline"
        },
        {
          "command": "codrag.startWatcher",
          "when": "view == codrag.indexStatus && viewItem == watcher_disabled",
          "group": "inline"
        },
        {
          "command": "codrag.stopWatcher",
          "when": "view == codrag.indexStatus && viewItem == watcher_enabled",
          "group": "inline"
        },
        {
          "command": "codrag.traceLookup",
          "when": "view == codrag.indexStatus && viewItem == trace",
          "group": "inline"
        },
        {
          "command": "codrag.buildIndex",
          "when": "view == codrag.indexStatus && viewItem == stale",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codrag.search",
        "key": "ctrl+alt+s",
        "mac": "cmd+opt+s",
        "when": "editorTextFocus"
      },
      {
        "command": "codrag.assembleContext",
        "key": "ctrl+alt+c",
        "mac": "cmd+opt+c"
      },
      {
        "command": "codrag.buildIndex",
        "key": "ctrl+alt+b",
        "mac": "cmd+opt+b"
      },
      {
        "command": "codrag.traceLookup",
        "key": "ctrl+alt+t",
        "mac": "cmd+opt+t"
      }
    ],
    "configuration": {
      "title": "CoDRAG",
      "properties": {
        "codrag.daemon.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "CoDRAG daemon host address"
        },
        "codrag.daemon.port": {
          "type": "number",
          "default": 8400,
          "description": "CoDRAG daemon port"
        },
        "codrag.daemon.executable": {
          "type": "string",
          "default": "codrag",
          "description": "Path to the CoDRAG executable (or command name if on PATH)"
        },
        "codrag.daemon.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the CoDRAG daemon when the extension activates"
        },
        "codrag.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CoDRAG status in the status bar"
        },
        "codrag.pollingInterval": {
          "type": "number",
          "default": 10000,
          "description": "Health check polling interval in milliseconds",
          "minimum": 2000,
          "maximum": 60000
        }
      }
    },
    "chatParticipants": [
      {
        "id": "codrag.chat",
        "name": "codrag",
        "fullName": "CoDRAG",
        "description": "Ask questions about your codebase using CoDRAG's semantic index.",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:webview && node esbuild.mjs",
    "build:webview": "cd webview-ui && npm install && npm run build",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "esbuild": "^0.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  }
}
